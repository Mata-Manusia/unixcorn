[Unit]
Description=Unixcorn Go Daemon
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=simple
User=root
WorkingDirectory=/root/unixcorn
Environment=DATABASE_URL=postgres://unixcorn:unixcorn123@localhost:5432/unixcorn?sslmode=disable
Environment=GIN_MODE=release
ExecStart=/root/unixcorn/bin/daemon
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
