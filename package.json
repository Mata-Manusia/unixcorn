{
  "name": "unixcorn",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:web": "npm --workspace=apps/web run dev",
    "dev:daemon": "cd apps/daemon && go run ./cmd/daemon",
    "build:web": "npm --workspace=apps/web run build",
    "build:daemon": "cd apps/daemon && go build -o ../../bin/daemon ./cmd/daemon"
  }
}
